{
  "$schema": "../app-info-schema.json",
  "name": "Telegram Delay Channel Cloner",
  "available": true,
  "exposable": false,
  "dynamic_config": true,
  "port": 8517,
  "id": "telegram-delay-cloner",
  "tipi_version": 1,
  "version": "0.0.1",
  "categories": [
    "social",
    "automation"
  ],
  "description": "A Telegram bot that relays messages between channels with configurable delay and batch processing. Set a source channel, target channel, and delay interval. Messages are queued in a SQLite database and forwarded at the configured pace. Useful for content scheduling and cross-posting.",
  "short_desc": "Relay Telegram messages between channels with configurable delay.",
  "author": "GeiserX",
  "source": "https://github.com/GeiserX/telegram-delay-channel-cloner",
  "form_fields": [
    {
      "type": "text",
      "label": "Bot Token",
      "env_variable": "BOT_TOKEN",
      "required": true
    },
    {
      "type": "text",
      "label": "Source Channel ID",
      "env_variable": "SOURCE_CHANNEL",
      "required": true
    },
    {
      "type": "text",
      "label": "Target Channel ID",
      "env_variable": "TARGET_CHANNEL",
      "required": true
    },
    {
      "type": "number",
      "label": "Delay (seconds)",
      "env_variable": "DELAY",
      "required": false,
      "default": 60
    },
    {
      "type": "number",
      "label": "Polling Interval (seconds)",
      "env_variable": "POLLING",
      "required": false,
      "default": 30
    }
  ],
  "supported_architectures": [
    "arm64",
    "amd64"
  ],
  "created_at": 1775057822856,
  "updated_at": 1775057822856,
  "min_tipi_version": "4.0.0",
  "no_gui": true
}
